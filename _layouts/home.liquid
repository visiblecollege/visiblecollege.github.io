---
layout: default
---

{%- comment -%}
  VC Brand Refresh — hero banner replaces the old logo/profile image block
{%- endcomment -%}
<div class="vc-hero" aria-label="Site hero">
  <div class="vc-hero-inner">
    <h1>A multidisciplinary collective of scholars and researchers focusing on anomalous phenomena</h1>
  </div>
</div>

<div class="home post">
  <article>
    {{ content }}

    <!-- News -->
    {% if page.news and site.announcements.enabled %}
      <hr class="vc-divider">
      <h4>
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">Latest <strong>news</strong></a>
      </h4>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Articles -->
    {% if site.articles_list.enabled %}
      <hr class="vc-divider">
      <h4>
        <a href="{{ '/articles/' | relative_url }}" style="color: inherit">Featured <strong>articles</strong></a>
      </h4>
      {% include articles_list.liquid %}
    {% endif %}

    <!-- Latest posts -->
    {% if site.latest_posts.enabled %}
      <hr class="vc-divider">
      <h4>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">Latest <strong>posts</strong></a>
      </h4>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <hr class="vc-divider">
      <h4>
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">Selected <strong>publications</strong></a>
      </h4>
      {% include selected_papers.liquid %}
    {% endif %}

    <!-- Social -->
    {% if page.social %}
      <div class="social">
        <div class="contact-icons">{% include social.liquid %}</div>
        <div class="contact-note">{{ site.contact_note }}</div>
      </div>
    {% endif %}

    {% if site.newsletter.enabled and site.footer_fixed %}
      {% include scripts/newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>
