<article class="profiles-include">
  {% if site.data.profiles %}
    {% for profile_group in site.data.profiles.groups %}
      {% assign group_slug = profile_group.label | downcase | replace: " ", "-" %}
      <a name="{{ group_slug }}"><h3{% unless forloop.first %} style="margin-top: 3.5rem;"{% endunless %}>{{ profile_group.label }}</h3></a>
      {{ profile_group.summary }}
      <div class="profiles-group"{% if profile_group.label == "Members" %} data-shuffle="true"{% endif %}>
      {% for profile in profile_group.members %}
        <div class="profile-entry">
        <hr/>
        <div class="profile float-{% if profile.align == 'right' %}right{% else %}left{% endif %}">
          {% if profile.image %}
            {% assign profile_image_path = profile.image | prepend: 'assets/img/' %}
            {% if profile.image_circular %}
              {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
            {% else %}
              {% assign profile_image_class = 'img-fluid z-depth-1 rounded' %}
            {% endif %}
            {% capture sizes %}(min-width: {{site.max_width}}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px) 30vw, 95vw"{% endcapture %}
            {% include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=profile.image %}
          {% endif %}
          {% if profile.more_info %}
            <div class="more-info">{{ profile.more_info }}</div>
          {% endif %}
        </div>

        <div class="clearfix">
          <h5 style="margin-bottom: 0.1rem">
            <strong>
              {% if profile.profile_page %}
                <a href="{{ profile.profile_page | relative_url }}">{{ profile.name }}</a>
              {% else %}
                {{ profile.name }}
              {% endif %}
            </strong>
          </h5>
          {% if profile.title %}
            <h6>{{ profile.title }}</h6>
          {% endif  %}
          {% if profile.bio %}
            {% capture profile_content %}{% include_relative {{ profile.bio }} %}{% endcapture %}
            {{ profile_content | markdownify }}
          {% endif %}
          <div class="publications-container">
            <div class="publications float-left">
              {% bibliography --sort_by year --order descending --group_by none --query @*[author_id~=\|{{ profile.id }}\|] %}
            </div>
          </div>
        </div>
        </div>
      {% endfor %}
      </div>
      {% if profile_group.closing %}
        <hr/>
        <div class="profile-group-closing">{{ profile_group.closing | markdownify }}</div>
      {% endif %}
    {% endfor %}
  {% endif %}
</article>

<script>
  (function () {
    function shuffle(container) {
      var items = Array.prototype.slice.call(container.querySelectorAll(":scope > .profile-entry"));
      for (var i = items.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var tmp = items[i];
        items[i] = items[j];
        items[j] = tmp;
      }
      items.forEach(function (el) {
        container.appendChild(el);
      });
    }
    document.querySelectorAll('.profiles-group[data-shuffle="true"]').forEach(shuffle);
  })();
</script>
